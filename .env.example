# =============================================================================
# OmniDynamic Engine — Environment Variables
# Copy this file to .env and fill in all values.
# NEVER commit .env to version control.
# =============================================================================

# -- Supabase (Database + Auth) --
# Found at: https://app.supabase.com → Project Settings → API
SUPABASE_URL=https://<your-project-ref>.supabase.co
SUPABASE_ANON_KEY=<anon-jwt-from-supabase-dashboard>
SUPABASE_SERVICE_ROLE_KEY=<service-role-jwt-from-supabase-dashboard>
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
DB_HOST=aws-0-<region>.pooler.supabase.com
DB_PORT=6543
DB_USER=postgres
DB_NAME=postgres
DB_PASSWORD=<your-database-password>

# -- Frontend (Next.js) --
# NEXT_PUBLIC_* are exposed to the browser — use anon key only, never service_role
NEXT_PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-jwt-from-supabase-dashboard>
NEXT_PUBLIC_GATEWAY_URL=http://localhost:3001
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -- API Gateway (NestJS) --
GATEWAY_PORT=3001
# Generate with: openssl rand -base64 32  — NEVER use a predictable value in production
JWT_SECRET=<generate-with-openssl-rand-base64-32>
GATEWAY_SUPABASE_URL=https://<your-project-ref>.supabase.co
GATEWAY_SUPABASE_SERVICE_ROLE_KEY=<service-role-jwt-from-supabase-dashboard>
PRICING_SOLVER_GRPC_HOST=localhost
PRICING_SOLVER_GRPC_PORT=50051
ORDER_SERVICE_URL=http://localhost:3004

# -- Ingestion Layer (Java) --
INGESTION_PORT=3002
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_INVENTORY=inventory-events

# -- Pricing Solver (C++) --
PRICING_SOLVER_HTTP_PORT=3003
REDIS_HOST=localhost
REDIS_PORT=6379
# GF_ADMIN credentials for Grafana (change on first login)
GF_ADMIN_USER=admin
GF_ADMIN_PASSWORD=<choose-a-strong-password>

# -- Order Service (.NET) --
ORDER_SERVICE_PORT=3004
AKKA_CLUSTER_SEED=akka://OmniDynamic@localhost:2551
SUPABASE_DB_URL_ORDERS=${DATABASE_URL}

# -- Kafka --
KAFKA_BROKER=localhost:9092
KAFKA_ZOOKEEPER=localhost:2181

# -- Redis --
REDIS_URL=redis://localhost:6379

# -- Docker / Registry --
DOCKER_REGISTRY=docker.io/your-username

# -- Kubernetes --
K8S_NAMESPACE=omnidynamic
HELM_RELEASE_NAME=omnidynamic
