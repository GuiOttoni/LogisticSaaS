# =============================================================================
# OmniDynamic Engine - Environment Variables Example
# Copy this file to .env and fill in all values
# =============================================================================

# -- Supabase (Database + Auth) --
SUPABASE_URL=https://<your-project>.supabase.co
SUPABASE_ANON_KEY=<your-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>
DATABASE_URL=postgresql://postgres:<password>@db.<project>.supabase.co:5432/postgres

# -- Frontend (Next.js) --
NEXT_PUBLIC_SUPABASE_URL=${SUPABASE_URL}
NEXT_PUBLIC_SUPABASE_ANON_KEY=${SUPABASE_ANON_KEY}
NEXT_PUBLIC_GATEWAY_URL=http://localhost:3001
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -- API Gateway (NestJS) --
GATEWAY_PORT=3001
JWT_SECRET=change-me-to-a-long-random-string
GATEWAY_SUPABASE_URL=${SUPABASE_URL}
GATEWAY_SUPABASE_SERVICE_ROLE_KEY=${SUPABASE_SERVICE_ROLE_KEY}
PRICING_SOLVER_GRPC_HOST=localhost
PRICING_SOLVER_GRPC_PORT=50051
ORDER_SERVICE_URL=http://localhost:3004

# -- Ingestion Layer (Java) --
INGESTION_PORT=3002
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_INVENTORY=inventory-events

# -- Pricing Solver (C++) --
PRICING_SOLVER_HTTP_PORT=3003
PRICING_SOLVER_GRPC_PORT=50051
REDIS_HOST=localhost
REDIS_PORT=6379
SUPABASE_DB_URL=${DATABASE_URL}

# -- Order Service (.NET) --
ORDER_SERVICE_PORT=3004
AKKA_CLUSTER_SEED=akka://OmniDynamic@localhost:2551
SUPABASE_DB_URL_ORDERS=${DATABASE_URL}

# -- Kafka --
KAFKA_BROKER=localhost:9092
KAFKA_ZOOKEEPER=localhost:2181

# -- Redis --
REDIS_URL=redis://localhost:6379

# -- Docker / Registry --
DOCKER_REGISTRY=docker.io/your-username

# -- Kubernetes --
K8S_NAMESPACE=omnidynamic
HELM_RELEASE_NAME=omnidynamic
